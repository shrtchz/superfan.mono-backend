enum HistoryType {
  REPORT
  FEEDBACK
}

enum SubmittedBy {
  ADMIN
  USER
  SYSTEM
}

enum PayoutStatus {
  COMPLETED
  PENDING
}

enum PayoutMethod {
  BUSHA
  FLUTTERWAVE
  MONNIFY
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum ActivityType {
  user_registered
  content_approved
  report_submitted
  subadmin_registered
  credit
  debit
}

enum ActivityStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ReferralStatus {
  CLICKED
  SIGNED_UP
  FIRST_TEST_COMPLETED
}

enum SubscriptionPlan {
  FREE
  PREMIUM_PRO
  PREMIUM_PRO_MAX
}

// enum Language {
//   yoruba
//   igbo
//   hausa
// }

// enum Subject {
//   general
//   proverbs
//   folktale
//   sports
//   politics
//   drama
// }

enum TestLevel {
  basic
  intermediate
  advanced
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID_OUT
}

enum QuestionPreference {
  Q5    @map("5")
  Q25   @map("25")
  Q50   @map("50")
  Q100  @map("100")
  Q200  @map("200")
  Q400  @map("400")
  Q1000 @map("1000")
}

enum TimePreference {
  T5        @map("5")
  T25       @map("25")
  T15       @map("15")
  T30       @map("30")
  T45       @map("45")
  T60       @map("60")
  UNLIMITED @map("unlimited")
}

enum BankTransferStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  CANCELLED
  SUCCESS
}
