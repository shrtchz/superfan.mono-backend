{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": ["mail/templates/**/*"],
    "watchAssets": true,
    "deleteOutDir": true
  },
  "watchOptions": {
    "watchIWD": false,
    "ignored": ["**/node_modules", "**/dist"]
  }
}
