<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Email Service Test</title>
</head>
<body
  style="
    margin: 0;
    padding: 0;
    background-color: #f4f4f4;
    font-family: Arial, Helvetica, sans-serif;
  "
>
  <table
    width="100%"
    cellpadding="0"
    cellspacing="0"
    border="0"
    style="background-color: #f4f4f4; padding: 40px 0;"
  >
    <tr>
      <td align="center">
        <table
          width="600"
          cellpadding="0"
          cellspacing="0"
          border="0"
          style="
            background-color: #ffffff;
            border-radius: 8px;
            overflow: hidden;
          "
        >
          <!-- Header -->
          <tr>
            <td
              align="center"
              style="
                background-color: #2563eb;
                color: #ffffff;
                padding: 30px;
                font-size: 28px;
                font-weight: bold;
              "
            >
              Email Service Test
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 40px;">
              <h2 style="margin-top: 0; color: #333333;">
                Email Delivery Verification
              </h2>

              <p
                style="
                  font-size: 16px;
                  line-height: 1.6;
                  color: #555555;
                "
              >
                Congratulations! If you are reading this email, your email
                service is working correctly.
              </p>

              <table
                width="100%"
                cellpadding="10"
                cellspacing="0"
                border="1"
                style="
                  border-collapse: collapse;
                  margin: 20px 0;
                  border-color: #dddddd;
                "
              >
                <tr>
                  <td><strong>Status</strong></td>
                  <td>✅ Success</td>
                </tr>
                <tr>
                  <td><strong>Environment</strong></td>
                  <td>Testing</td>
                </tr>
                <tr>
                  <td><strong>Timestamp</strong></td>
                  <td>{{timestamp}}</td>
                </tr>
                <tr>
                  <td><strong>Recipient</strong></td>
                  <td>{{email}}</td>
                </tr>
              </table>

              <p
                style="
                  font-size: 16px;
                  line-height: 1.6;
                  color: #555555;
                "
              >
                This email was generated automatically to verify email delivery,
                rendering, and inbox placement.
              </p>

              <div style="text-align: center; margin-top: 30px;">
                <a
                  href="https://example.com"
                  style="
                    display: inline-block;
                    background-color: #2563eb;
                    color: #ffffff;
                    text-decoration: none;
                    padding: 12px 24px;
                    border-radius: 6px;
                    font-weight: bold;
                  "
                >
                  Test Button
                </a>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td
              align="center"
              style="
                background-color: #f8f9fa;
                padding: 20px;
                color: #777777;
                font-size: 13px;
              "
            >
              This is an automated test email.<br />
              Generated by your NestJS application.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>