<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to Superfan</title>
</head>

<body style="margin: 0; padding: 0; background-color: #f4f4f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; color: #111827;">

  <table width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse;">
    <tr>
      <td align="center" style="padding: 24px;">
        
        <!-- Main Container with Shadow Effect (simulated via border) -->
        <table width="100%" cellpadding="0" cellspacing="0" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; overflow: hidden; border: 1px solid #e5e7eb; box-shadow: 8px 8px 0px #000000;">

          <!-- Header -->
          <tr>
            <td style="background-color: #ffffff; text-align: center; padding: 32px 20px 24px; color: #000000; border-bottom: 1px solid #f3f4f6;">
              <!-- Logo -->
              <table align="center" cellpadding="0" cellspacing="0" role="presentation">
                <tr>
                  <td align="center" style="padding-bottom:16px;">
                    <img
                      src="https://cloudflare-b2.shrtchz.workers.dev/image3.png"
                      alt="Superfan"
                      width="150"
                      style="display:block; margin:0 auto; max-width:150px; height:auto; border: 0;"
                    />
                  </td>
                </tr>
              </table>
          
              <h1 style="margin: 0; font-size: 20px; font-weight: 700; color: #111827;">Welcome to Superfan</h1>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding: 32px 32px 24px;">

              <div style="font-size: 16px; font-weight: 700; margin-bottom: 12px; color: #111827;">
                Hey {{username}}!
              </div>

              <div style="font-size: 14px; line-height: 1.6; color: #6b7280; margin-bottom: 24px;">
                We're thrilled to have you join the Superfan community! Your account is
                now active and ready to go.
              </div>

              <div style="font-size: 14px; font-weight: 700; color: #111827; margin-bottom: 16px;">
                Here's what you can do next:
              </div>

              <!-- Checklist Items -->
              <div style="margin-bottom: 32px;">
                
                <!-- Item 1 -->
                <div style="border: 1px solid #e5e7eb; border-radius: 4px; padding: 12px 16px; margin-bottom: 12px; display: flex; align-items: center;">
                  <span style="color: #22c55e; font-weight: bold; font-size: 16px; margin-right: 12px;">✓</span>
                  <span style="font-size: 13px; color: #374151; font-weight: 500;">Complete your KYC to unlock all features</span>
                </div>

                <!-- Item 2 -->
                <div style="border: 1px solid #e5e7eb; border-radius: 4px; padding: 12px 16px; margin-bottom: 12px; display: flex; align-items: center;">
                  <span style="color: #22c55e; font-weight: bold; font-size: 16px; margin-right: 12px;">✓</span>
                  <span style="font-size: 13px; color: #374151; font-weight: 500;">Explore exclusive content</span>
                </div>

                <!-- Item 3 -->
                <div style="border: 1px solid #e5e7eb; border-radius: 4px; padding: 12px 16px; margin-bottom: 12px; display: flex; align-items: center;">
                  <span style="color: #22c55e; font-weight: bold; font-size: 16px; margin-right: 12px;">✓</span>
                  <span style="font-size: 13px; color: #374151; font-weight: 500;">Challenge other superfans</span>
                </div>

              </div>

              <!-- CTA Button -->
              <div style="text-align: center; margin-bottom: 32px;">
                <a
                  href="https://superfan.co/dashboard"
                  style="display: inline-block; background-color: #000000; color: #ffffff; text-decoration: none; padding: 12px 48px; border-radius: 999px; font-size: 14px; font-weight: 700;"
                >
                  Get Started
                </a>
              </div>

              <!-- Support -->
              <div style="font-size: 13px; color: #6b7280; text-align: center;">
                If you have any questions, shoot an email to
                <strong style="color: #111827;">superfanng@superfan.ng</strong>
              </div>

            </td>
          </tr>
          
          <!-- Divider -->
          <tr>
             <td style="padding: 0 32px;">
               <hr style="border: none; border-top: 1px solid #f3f4f6;" />
             </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding: 24px 20px;">
              <div style="font-size: 13px; color: #111827; font-weight: 500; margin-bottom: 4px;">
                With love,
              </div>
              <div style="font-size: 13px; color: #111827; font-weight: 700; margin-bottom: 16px;">
                The Superfan NG Team <span style="color: #ef4444;">♥</span>
              </div>
              
              <div style="font-size: 11px; color: #9ca3af;">
                © 2026 Superfan NG. All rights reserved.<br />
                You're receiving this email because you signed up for a Superfan account.
              </div>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>

</body>
</html>
